generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model SiteSettings {
  id             String   @id @default(cuid())
  whatsappNumber String
  updatedAt      DateTime @updatedAt

  @@map("site_settings")
}

model Developer {
  id          String    @id @default(cuid())
  name        String    @unique
  logoUrl     String?
  website     String?
  established Int?
  projects    Project[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("developers")
}

model Project {
  id             String          @id @default(cuid())
  developerId    String
  developer      Developer       @relation(fields: [developerId], references: [id])
  name           String
  slug           String          @unique
  location       String
  city           String
  locality       String?
  description    String?
  amenities      String? // Comma-separated list of amenities, e.g. "Pool, Gym, Clubhouse"
  latitude       Float?
  longitude      Float?
  configurations Configuration[]
  images         ProjectImage[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@map("projects")
}

model ProjectImage {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  url       String
  label     String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@map("project_images")
}

model Configuration {
  id             String      @id @default(cuid())
  projectId      String
  project        Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  bhk            Int
  variantName    String
  carpetArea     Float
  pricePerSqft   Float
  status         String // "NEW_LAUNCH" | "UNDER_CONSTRUCTION" | "READY_TO_MOVE" | "SOLD_OUT"
  possessionDate DateTime?
  reraId         String?
  floorPlans     FloorPlan[]
  inventory      Inventory[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@map("configurations")
}

model FloorPlan {
  id              String        @id @default(cuid())
  configurationId String
  configuration   Configuration @relation(fields: [configurationId], references: [id], onDelete: Cascade)
  type            String // "MASTER_LAYOUT" | "FLOOR_PLATE" | "UNIT_LAYOUT"
  label           String
  url             String
  sortOrder       Int           @default(0)
  createdAt       DateTime      @default(now())

  @@map("floor_plans")
}

model Inventory {
  id              String        @id @default(cuid())
  configurationId String
  configuration   Configuration @relation(fields: [configurationId], references: [id], onDelete: Cascade)
  unitNumber      String
  floor           Int
  facing          String?
  priceOverride   Float?
  status          String        @default("AVAILABLE") // "AVAILABLE" | "BOOKED" | "HOLD" | "SOLD"
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([configurationId, unitNumber])
  @@map("inventory")
}
